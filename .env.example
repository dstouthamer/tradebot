# ---- AI Boekhouder configuration (copy to .env) ----
# Everything is optional: with no values set, the system runs fully keyless
# (deterministic stubs, local concepts, no outbound calls).

# Company profile (section 1 of the masterprompt) ---------------------------
BOEKHOUDER_COMPANY_NAME="Mijn Bedrijf"
BOEKHOUDER_LEGAL_FORM="EENMANSZAAK"        # EENMANSZAAK / BV / VOF / ANDERS
BOEKHOUDER_KVK=""
BOEKHOUDER_BTW_ID=""
BOEKHOUDER_IBAN=""
BOEKHOUDER_SECTOR="INSTALLATIE"
BOEKHOUDER_VAT_PERIOD="KWARTAAL"           # MAAND / KWARTAAL / JAAR
BOEKHOUDER_PAYMENT_TERM_DAYS=14
BOEKHOUDER_QUOTE_VALIDITY_DAYS=30
BOEKHOUDER_ACCOUNTANT_CONTACT=""

# Compliance / safety (safe-by-default — change with care) -----------------
BOEKHOUDER_REQUIRE_CONFIRMATION=true       # never book/send/file without an explicit OK
BOEKHOUDER_ALLOW_AUTO_SEND=false           # master switch for any outbound send

# Auth & multi-tenant -------------------------------------------------------
# VERPLICHT in productie: lange willekeurige waarde (tekent sessietokens).
# Genereer: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
BOEKHOUDER_SECRET_KEY=""
BOEKHOUDER_ALLOW_SIGNUP=true               # open registratie aan/uit
# Gratis social login (vul id+secret om te activeren):
BOEKHOUDER_GOOGLE_CLIENT_ID=""
BOEKHOUDER_GOOGLE_CLIENT_SECRET=""
BOEKHOUDER_MICROSOFT_CLIENT_ID=""
BOEKHOUDER_MICROSOFT_CLIENT_SECRET=""
BOEKHOUDER_OAUTH_REDIRECT_BASE="https://boekhouder.jouwdomein.nl"
# iDIN banklogin (BETAALD — broker-contract vereist; zonder dit blijft de knop verborgen):
BOEKHOUDER_IDIN_BROKER=""                  # signicat | cm | bank
BOEKHOUDER_IDIN_CLIENT_ID=""
BOEKHOUDER_IDIN_CLIENT_SECRET=""

# Integrations (leave blank to stay keyless) -------------------------------
BOEKHOUDER_TELEGRAM_TOKEN=""               # enable the real Telegram intake bot
# WhatsApp via Meta Cloud API (gratis tier; vereist Meta-bedrijfsaccount + nummer):
BOEKHOUDER_WHATSAPP_TOKEN=""               # permanent access token van je Meta-app
BOEKHOUDER_WHATSAPP_PHONE_ID=""            # phone number id
BOEKHOUDER_WHATSAPP_VERIFY_TOKEN=""        # zelfgekozen string voor webhook-verificatie
BOEKHOUDER_MONEYBIRD_TOKEN=""              # personal access / OAuth token
BOEKHOUDER_MONEYBIRD_ADMIN_ID=""           # Moneybird administration id
BOEKHOUDER_OCR_PROVIDER="auto"             # auto | tesseract | stub
# Factuur-mailbox (IMAP): apart adres waar alleen facturen binnenkomen ->
# 'python -m boekhouder.mail_fetch' haalt de bijlagen op als conceptboeking.
BOEKHOUDER_IMAP_HOST=""                     # bv. imap.gmail.com
BOEKHOUDER_IMAP_USER=""                     # bv. facturen@klimaatkampioen.nl
BOEKHOUDER_IMAP_PASSWORD=""                 # app-wachtwoord
BOEKHOUDER_IMAP_FOLDER="INBOX"
BOEKHOUDER_IMAP_SSL="true"
# Obsidian-export: schrijf je boekhouding als Markdown-notities naar een lokale
# Obsidian-vault. Leeg = uit. Schrijft alleen lokale bestanden (geen netwerk) ->
# in de CLI: '/obsidian'.
BOEKHOUDER_OBSIDIAN_VAULT=""               # bv. /Users/jij/Obsidian/Werk
BOEKHOUDER_OBSIDIAN_FOLDER="Boekhouding"   # submap in de vault
BOEKHOUDER_ANTHROPIC_API_KEY=""            # enable the ClaudeLLM reasoning seam

# Database: leeg = sqlite (lokaal/MVP). Voor schaal/productie een Postgres-URL
# (vereist: pip install "psycopg[binary]"):
BOEKHOUDER_DATABASE_URL=""                 # bv. postgresql://user:pass@host:5432/boekhouder

BOEKHOUDER_LOG_LEVEL="INFO"
